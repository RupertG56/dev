## system-wide
## /etc/systemd/system/podman_init@.service
## sudo systemctl enable --now podman_init@samba
##
## per user
## mkdir -p $HOME/.config/systemd/user
## copy to $HOME/.config/systemd/user/podman_init@.service
## run `systemctl --user enable --now podman_init@<container_name>`
[Unit]
Description=Start Podman Container %i
After=network.target

[Service]
Restart=always
ExecStart=/usr/bin/podman start -a %i
ExecStop=/usr/bin/podman stop -t 10 %i

[Install]
WantedBy=multi-user.target

